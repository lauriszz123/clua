{
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:ClassName}",
      "\tvar ${2:fieldName}: ${3:Type}",
      "",
      "\tfunction new(${4:paramName}: ${5:Type})",
      "\t\tself.${2:fieldName} = ${4:paramName}",
      "\tend",
      "end",
      "",
      "return ${1:ClassName}"
    ],
    "description": "Create a CLua class"
  },
  "Method": {
    "prefix": "method",
    "body": [
      "function ${1:methodName}(${2:paramName}: ${3:Type}): ${4:ReturnType}",
      "\t${0}",
      "end"
    ],
    "description": "Create a typed CLua method"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "local function ${1:functionName}(${2:paramName}: ${3:Type}): ${4:ReturnType}",
      "\t${0}",
      "end"
    ],
    "description": "Create a typed CLua function"
  },
  "Var": {
    "prefix": "var",
    "body": [
      "var ${1:fieldName}: ${2:Type}${3: = ${4:value}}${0}"
    ],
    "description": "Create a typed CLua field"
  },
  "Typed local": {
    "prefix": "localt",
    "body": [
      "local ${1:varName}: ${2:Type} = ${3:value}${0}"
    ],
    "description": "Create a typed local declaration"
  },
  "Runtime assert": {
    "prefix": "assertt",
    "body": [
      "__clua_runtime.assert_type(${1:value}, \"${2:expectedType}\", \"${3:location}\")${0}"
    ],
    "description": "Insert a CLua runtime type assertion"
  },
  "Try Catch": {
    "prefix": "try",
    "body": [
      "try",
      "\t${1:tryCode}",
      "catch ${2:err}",
      "\t${3:catchCode}",
      "end${0}"
    ],
    "description": "Create a CLua try/catch block"
  },
  "Try Finally": {
    "prefix": "tryf",
    "body": [
      "try",
      "\t${1:tryCode}",
      "finally",
      "\t${2:finallyCode}",
      "end${0}"
    ],
    "description": "Create a CLua try/finally block"
  },
  "Try Catch Finally": {
    "prefix": "trycf",
    "body": [
      "try",
      "\t${1:tryCode}",
      "catch ${2:err}",
      "\t${3:catchCode}",
      "finally",
      "\t${4:finallyCode}",
      "end${0}"
    ],
    "description": "Create a CLua try/catch/finally block"
  }
}
