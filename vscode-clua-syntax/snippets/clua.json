{
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:Name}",
      "\tvar ${2:field}: ${3:number}",
      "",
      "\tfunction new(${4:value}: ${3:number})",
      "\t\tself.${2:field} = ${4:value}",
      "\tend",
      "end",
      "",
      "return ${1:Name}"
    ],
    "description": "Create a CLua class"
  },
  "Method": {
    "prefix": "method",
    "body": [
      "function ${1:name}(${2:param}: ${3:number})",
      "\t${0}",
      "end"
    ],
    "description": "Create a typed CLua method"
  },
  "Var": {
    "prefix": "var",
    "body": [
      "var ${1:name}: ${2:number}${3: = ${4:0}}"
    ],
    "description": "Create a typed CLua field"
  },
  "Typed local": {
    "prefix": "localt",
    "body": [
      "local ${1:name}: ${2:number} = ${3:0}"
    ],
    "description": "Create a typed local declaration"
  },
  "Runtime assert": {
    "prefix": "assertt",
    "body": [
      "__clua_runtime.assert_type(${1:value}, \"${2:number}\", \"${3:where}\")"
    ],
    "description": "Insert a CLua runtime type assertion"
  }
}
