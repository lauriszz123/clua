{
  "name": "CLua",
  "scopeName": "source.clua",
  "patterns": [
    {
      "include": "#documentation"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#genericTypeArguments"
    },
    {
      "include": "#classDeclaration"
    },
    {
      "include": "#enumDeclaration"
    },
    {
      "include": "#functionDeclaration"
    },
    {
      "include": "#importDeclaration"
    },
    {
      "include": "#varDeclaration"
    },
    {
      "include": "#typedLocals"
    },
    {
      "include": "#localDeclarations"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constructorCalls"
    },
    {
      "include": "#selfMemberAccess"
    },
    {
      "include": "#methodCalls"
    },
    {
      "include": "#memberAccess"
    },
    {
      "include": "#functionCalls"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "documentation": {
      "patterns": [
        {
          "name": "comment.line.documentation.param.clua",
          "match": "^(\\s*---\\s*)(@param)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_\\.]*)(?:\\s+(.*))?$",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.clua"
            },
            "2": {
              "name": "keyword.other.documentation.param.clua"
            },
            "3": {
              "name": "variable.parameter.documentation.clua"
            },
            "4": {
              "name": "storage.type.documentation.clua"
            },
            "5": {
              "name": "comment.line.documentation.description.clua"
            }
          }
        },
        {
          "name": "comment.line.documentation.clua",
          "match": "^\\s*---.*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.clua",
          "match": "--.*$"
        },
        {
          "name": "comment.block.clua",
          "begin": "--\\[\\[",
          "end": "\\]\\]"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.clua",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.clua",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.clua",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.clua",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.other.long.clua",
          "begin": "\\[(=*)\\[",
          "end": "\\]\\1\\]"
        }
      ]
    },
    "classDeclaration": {
      "patterns": [
        {
          "name": "meta.class.clua",
          "match": "^\\s*(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*(<)\\s*([^>]+?)\\s*(>))?(?:\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_\\.<>\\[\\],\\s]*))?",
          "captures": {
            "1": {
              "name": "keyword.declaration.class.clua"
            },
            "2": {
              "name": "entity.name.type.class.clua"
            },
            "3": {
              "name": "punctuation.definition.typeparameters.begin.clua"
            },
            "4": {
              "name": "entity.name.type.type-parameter.clua"
            },
            "5": {
              "name": "punctuation.definition.typeparameters.end.clua"
            },
            "6": {
              "name": "keyword.declaration.inheritance.clua"
            },
            "7": {
              "name": "entity.other.inherited-class.clua"
            }
          }
        }
      ]
    },
    "enumDeclaration": {
      "patterns": [
        {
          "name": "meta.enum.clua",
          "begin": "^\\s*(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*$",
          "end": "^\\s*(end)\\s*$",
          "captures": {
            "1": {
              "name": "keyword.declaration.enum.clua"
            },
            "2": {
              "name": "entity.name.type.enum.clua"
            }
          },
          "patterns": [
            {
              "name": "meta.enum.member.clua",
              "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)(?:\\s*=\\s*(.+))?\\s*$",
              "captures": {
                "1": {
                  "name": "variable.other.enummember.clua"
                },
                "2": {
                  "name": "constant.numeric.clua"
                }
              }
            },
            {
              "include": "#comments"
            },
            {
              "include": "#numbers"
            }
          ],
          "endCaptures": {
            "1": {
              "name": "keyword.control.clua"
            }
          }
        }
      ]
    },
    "functionDeclaration": {
      "patterns": [
        {
          "name": "meta.function.clua",
          "begin": "^\\s*(local\\s+)?(function)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*(<)\\s*([^>]+?)\\s*(>))?\\s*(\\()",
          "end": "\\)",
          "beginCaptures": {
            "1": { "name": "storage.modifier.local.clua" },
            "2": { "name": "keyword.declaration.function.clua" },
            "3": { "name": "entity.name.function.clua" },
            "4": { "name": "punctuation.definition.typeparameters.begin.clua" },
            "5": { "name": "entity.name.type.type-parameter.clua" },
            "6": { "name": "punctuation.definition.typeparameters.end.clua" },
            "7": { "name": "punctuation.section.parameters.begin.clua" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.parameters.end.clua" }
          },
          "patterns": [
            { "include": "#typedParam" },
            {
              "name": "variable.parameter.clua",
              "match": "[A-Za-z_][A-Za-z0-9_]*"
            }
          ]
        },
        {
          "name": "meta.function.return-type.clua",
          "match": "(?<=\\))\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_\\.<>\\[\\],\\s:]*)",
          "captures": {
            "1": { "name": "punctuation.separator.type.clua" },
            "2": { "name": "storage.type.clua" }
          }
        }
      ]
    },
    "localDeclarations": {
      "patterns": [
        {
          "name": "meta.local.untyped.clua",
          "match": "^\\s*(local)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:=|$))",
          "captures": {
            "1": {
              "name": "storage.modifier.local.clua"
            },
            "2": {
              "name": "variable.other.local.clua"
            }
          }
        }
      ]
    },
    "importDeclaration": {
      "patterns": [
        {
          "name": "meta.import.clua",
          "match": "^\\s*(import)\\s+((?:[a-z_][A-Za-z0-9_]*\\.)*)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.clua"
            },
            "2": {
              "name": "entity.name.namespace.clua"
            },
            "3": {
              "name": "entity.name.type.class.clua"
            }
          }
        }
      ]
    },
    "varDeclaration": {
      "patterns": [
        {
          "name": "meta.var.clua",
          "match": "^\\s*(var)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_\\.]*)(?:\\s*(<)\\s*([^>]+?)\\s*(>))?((?:\\s*\\[\\])*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.variable.clua"
            },
            "2": {
              "name": "variable.other.readwrite.clua"
            },
            "3": {
              "name": "punctuation.separator.type.clua"
            },
            "4": {
              "name": "storage.type.clua"
            },
            "5": {
              "name": "punctuation.definition.typeparameters.begin.clua"
            },
            "6": {
              "name": "entity.name.type.type-parameter.clua"
            },
            "7": {
              "name": "punctuation.definition.typeparameters.end.clua"
            },
            "8": {
              "name": "storage.modifier.array.clua"
            }
          }
        }
      ]
    },
    "typedLocals": {
      "patterns": [
        {
          "name": "meta.local.typed.clua",
          "match": "^\\s*(local)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_\\.]*)(?:\\s*(<)\\s*([^>]+?)\\s*(>))?((?:\\s*\\[\\])*)",
          "captures": {
            "1": {
              "name": "storage.modifier.local.clua"
            },
            "2": {
              "name": "variable.other.local.clua"
            },
            "3": {
              "name": "punctuation.separator.type.clua"
            },
            "4": {
              "name": "storage.type.clua"
            },
            "5": {
              "name": "punctuation.definition.typeparameters.begin.clua"
            },
            "6": {
              "name": "entity.name.type.type-parameter.clua"
            },
            "7": {
              "name": "punctuation.definition.typeparameters.end.clua"
            },
            "8": {
              "name": "storage.modifier.array.clua"
            }
          }
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "meta.typed.parameter.clua",
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_\\.]*)(?:\\s*(<)\\s*([^>]+?)\\s*(>))?((?:\\s*\\[\\])*)",
          "captures": {
            "1": {
              "name": "variable.parameter.clua"
            },
            "2": {
              "name": "punctuation.separator.type.clua"
            },
            "3": {
              "name": "storage.type.clua"
            },
            "4": {
              "name": "punctuation.definition.typeparameters.begin.clua"
            },
            "5": {
              "name": "entity.name.type.type-parameter.clua"
            },
            "6": {
              "name": "punctuation.definition.typeparameters.end.clua"
            },
            "7": {
              "name": "storage.modifier.array.clua"
            }
          }
        }
      ]
    },
    "genericTypeArguments": {
      "patterns": [
        {
          "name": "meta.generic.arguments.clua",
          "begin": "\\b([A-Za-z_][A-Za-z0-9_\\.]*)(<)",
          "end": ">",
          "beginCaptures": {
            "1": { "name": "entity.name.type.class.clua" },
            "2": { "name": "punctuation.definition.typeparameters.begin.clua" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.typeparameters.end.clua" }
          },
          "patterns": [
            {
              "name": "support.type.builtin.clua",
              "match": "\\b(any|nil|boolean|number|string|table|function|thread|userdata|Love)\\b"
            },
            {
              "name": "entity.name.type.type-parameter.clua",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "entity.name.type.class.clua",
              "match": "\\b[A-Za-z_][A-Za-z0-9_\\.]*\\b"
            },
            {
              "name": "punctuation.separator.comma.clua",
              "match": ","
            }
          ]
        }
      ]
    },
    "constructorCalls": {
      "patterns": [
        {
          "name": "meta.constructor.call.clua",
          "match": "\\b(new)\\s+([A-Za-z_][A-Za-z0-9_\\.<>\\[\\],\\s]*)\\s*(\\()",
          "captures": {
            "1": {
              "name": "keyword.operator.new.clua"
            },
            "2": {
              "name": "entity.name.type.class.clua"
            },
            "3": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        },
        {
          "name": "meta.constructor.call.rewritten.clua",
          "match": "\\b([A-Za-z_][A-Za-z0-9_\\.]*)\\s*(\\.)\\s*(new)\\s*(\\()",
          "captures": {
            "1": {
              "name": "entity.name.type.class.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "entity.name.function.constructor.clua"
            },
            "4": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        }
      ]
    },
    "methodCalls": {
      "patterns": [
        {
          "name": "meta.method.call.clua",
          "match": "\\b([A-Za-z_][A-Za-z0-9_\\.]*)\\s*(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "captures": {
            "1": {
              "name": "variable.other.object.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "entity.name.function.call.clua"
            },
            "4": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        },
        {
          "name": "meta.member.call.clua",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\s*(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "captures": {
            "1": {
              "name": "entity.name.type.class.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "entity.name.function.call.clua"
            },
            "4": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        }
      ]
    },
    "selfMemberAccess": {
      "patterns": [
        {
          "name": "meta.self.method.call.chain.clua",
          "match": "\\b(self)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*\\()",
          "captures": {
            "1": {
              "name": "constant.language.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "variable.other.member.clua"
            },
            "4": {
              "name": "punctuation.accessor.dot.clua"
            },
            "5": {
              "name": "entity.name.function.call.clua"
            },
            "6": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        },
        {
          "name": "meta.self.member.access.chain.clua",
          "match": "\\b(self)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(?!\\s*\\()",
          "captures": {
            "1": {
              "name": "constant.language.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "variable.other.member.clua"
            },
            "4": {
              "name": "punctuation.accessor.dot.clua"
            },
            "5": {
              "name": "variable.other.member.clua"
            }
          }
        },
        {
          "name": "meta.self.method.call.clua",
          "match": "\\b(self)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*\\()",
          "captures": {
            "1": {
              "name": "constant.language.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "entity.name.function.call.clua"
            },
            "4": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        },
        {
          "name": "meta.self.member.access.clua",
          "match": "\\b(self)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(?!\\s*\\()",
          "captures": {
            "1": {
              "name": "constant.language.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "variable.other.member.clua"
            }
          }
        }
      ]
    },
    "memberAccess": {
      "patterns": [
        {
          "name": "meta.member.access.chain.clua",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(?!\\s*\\()",
          "captures": {
            "1": {
              "name": "variable.other.object.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "variable.other.member.clua"
            },
            "4": {
              "name": "punctuation.accessor.dot.clua"
            },
            "5": {
              "name": "variable.other.member.clua"
            }
          }
        },
        {
          "name": "meta.member.access.clua",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)(\\s*\\.\\s*)([A-Za-z_][A-Za-z0-9_]*)(?!\\s*\\()",
          "captures": {
            "1": {
              "name": "variable.other.object.clua"
            },
            "2": {
              "name": "punctuation.accessor.dot.clua"
            },
            "3": {
              "name": "variable.other.member.clua"
            }
          }
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "meta.function.call.clua",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.clua"
            },
            "2": {
              "name": "punctuation.section.arguments.begin.clua"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.clua",
          "match": "\\b(class|enum|var|extends|function|end|if|then|else|elseif|for|while|repeat|until|do|return|break|in|and|or|not|local|new|import|try|catch|finally)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.clua",
          "match": "\\b(true|false|nil|self)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.clua",
          "match": "\\b(?:0x[0-9A-Fa-f]+|\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.clua",
          "match": "[+\\-*/%^#=<>~:.]+"
        }
      ]
    },
    "typedParam": {
      "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([A-Za-z_][A-Za-z0-9_.]*)",
      "captures": {
        "1": { "name": "variable.parameter.clua" },
        "2": { "name": "punctuation.separator.type.clua" },
        "3": { "name": "entity.name.type.clua" }
      }
    }
  },
  "uuid": "7f84f26f-9b5e-4dc3-b5da-2e115c6f8dca"
}
